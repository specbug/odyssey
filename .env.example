# Copy this file to .env and fill in the values

# Production origins allowed by FastAPI CORS (comma-separated)
# Replace with your actual subdomain once the tunnel is live
CORS_ORIGINS=https://odyssey.sixeleven.in

# Cloudflare Tunnel token — get this from:
# Cloudflare Zero Trust dashboard → Networks → Tunnels → Create a tunnel
# Set the tunnel ingress rule: https://odyssey.sixeleven.in → http://web:80
CLOUDFLARE_TUNNEL_TOKEN=your_tunnel_token_here

# Gemini metadata enrichment (optional)
# When set, uploaded PDFs get title / author / excerpt auto-extracted via the
# Google Generative Language API. Leave unset to disable — the backend degrades
# gracefully. Free-tier eligible with the default model.
# Get a key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# Override the model if you want flash-lite / 2.0-flash / a paid model.
# Default is gemini-2.5-flash.
# GEMINI_MODEL=gemini-2.5-flash
