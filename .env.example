# Copy this file to .env and fill in the values

# Production origins allowed by FastAPI CORS (comma-separated)
# Replace with your actual subdomain once the tunnel is live
CORS_ORIGINS=https://odyssey.sixeleven.in

# Cloudflare Tunnel token — get this from:
# Cloudflare Zero Trust dashboard → Networks → Tunnels → Create a tunnel
# Set the tunnel ingress rule: https://odyssey.sixeleven.in → http://web:80
CLOUDFLARE_TUNNEL_TOKEN=your_tunnel_token_here
