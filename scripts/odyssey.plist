<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>in.sixeleven.odyssey</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/rishitv/Documents/odyssey/scripts/start.sh</string>
    </array>

    <!-- Run at every login -->
    <key>RunAtLoad</key>
    <true/>

    <!-- Don't restart the launcher itself — compose handles container restarts -->
    <key>KeepAlive</key>
    <false/>

    <key>StandardOutPath</key>
    <string>/Users/rishitv/Library/Logs/odyssey.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/rishitv/Library/Logs/odyssey-error.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
        <key>HOME</key>
        <string>/Users/rishitv</string>
    </dict>
</dict>
</plist>
